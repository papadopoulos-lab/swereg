\if{html}{\out{<div class="r">}}\preformatted{TTEPlan$add_one_ett(
  enrollment_id,
  outcome_var,
  outcome_name,
  follow_up,
  confounder_vars,
  time_treatment_var,
  eligible_var,
  argset = list()
)}\if{html}{\out{</div>}}
}

